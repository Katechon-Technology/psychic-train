# Adapted from claudetorio/packages/vtuber-stream-client/conf.yaml.template.
# Diff: character_name / live2d_model_name / persona_prompt / voice_id are envsubst
# variables fed from the per-plugin manifest.
system_config:
  conf_version: 'v1.2.1'
  host: '0.0.0.0'
  port: 12393
  config_alts_dir: 'characters'
  tool_prompts:
    live2d_expression_prompt: 'live2d_expression_prompt'
    group_conversation_prompt: 'group_conversation_prompt'
    mcp_prompt: 'mcp_prompt'
    proactive_speak_prompt: 'proactive_speak_prompt'

character_config:
  conf_name: 'psychic-train'
  conf_uid: 'psychic_train_001'
  live2d_model_name: '${LIVE2D_MODEL}'
  character_name: '${CHARACTER_NAME}'
  avatar: ''
  human_name: 'Viewer'

  persona_prompt: |
    ${PERSONA_PROMPT}

  agent_config:
    conversation_agent_choice: 'basic_memory_agent'
    agent_settings:
      basic_memory_agent:
        llm_provider: 'claude_llm'
        faster_first_response: True
        segment_method: 'pysbd'
        use_mcpp: False
        mcp_enabled_servers: []

    llm_configs:
      claude_llm:
        base_url: 'https://api.anthropic.com'
        llm_api_key: '${ANTHROPIC_API_KEY}'
        model: 'claude-haiku-4-5-20251001'

  asr_config:
    asr_model: 'groq_whisper_asr'
    groq_whisper_asr:
      api_key: 'disabled'

  tts_config:
    tts_model: 'elevenlabs_tts'
    elevenlabs_tts:
      api_key: '${ELEVENLABS_API_KEY}'
      voice_id: '${VOICE_ID}'
      model_id: 'eleven_multilingual_v2'
      output_format: 'mp3_44100_128'
      stability: 0.5
      similarity_boost: 0.5
      style: 0.0
      use_speaker_boost: true

  vad_config:
    vad_model: null

  tts_preprocessor_config:
    remove_special_char: True
    ignore_brackets: True
    ignore_parentheses: True
    ignore_asterisks: True
    ignore_angle_brackets: True
    translator_config:
      translate_audio: False
      translate_provider: 'deeplx'

live_config:
  bilibili_live:
    room_ids: []
    sessdata: ''
