# Dependencies
node_modules/
.venv/
__pycache__/
*.pyc
.pip-packages/

# Build outputs
.next/
dist/
build/
*.egg-info/

# Environment files
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Logs
*.log
logs/

# Secrets
*.pem
*.key
credentials.json

# Plugin proprietary / generated / large files — plugins add finer-grained rules
# in their own .gitignore files.
# Factorio client binary: keep the directory tracked (README acts as .gitkeep)
# so the stream-client Dockerfile COPY works; ignore the actual binary contents.
plugins/factorio/factorio-client/*
!plugins/factorio/factorio-client/README.md
plugins/factorio/factorio-data/
plugins/minecraft/server/fabric-server-mc.*.jar
plugins/minecraft/server/libraries/
plugins/minecraft/server/versions/
plugins/minecraft/server/world/
plugins/minecraft/server/world_*/
plugins/minecraft/server/logs/
plugins/minecraft/server/.fabric/
plugins/minecraft/server/usercache.json
plugins/minecraft/server/node_modules/
# SPECTRE vendored source — populated by plugins/arcade/stream-client/seed-spectre.sh
# from the sibling katechon-app repo. Keep README so the COPY path exists.
plugins/arcade/stream-client/spectre/*
!plugins/arcade/stream-client/spectre/README.md

# Local dev data volumes
dev/postgres_data/
dev/redis_data/

# Top-level "bring your own binaries" tree. Plugins that need large pre-fetched
# datasets (e.g. minecraft client + assets) drop them under plugin-data/<plugin>/.
# Init services in dev/docker-compose.yml seed named volumes from these dirs;
# nothing here is committed. Keep the per-plugin READMEs so the dirs are
# tracked for the COPY/bind to find.
plugin-data/*
!plugin-data/README.md
!plugin-data/*/README.md

# Backups
backups/
