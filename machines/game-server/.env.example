# --- Postgres ---
POSTGRES_PASSWORD=changeme

# --- Broker ---
BROKER_ADMIN_KEY=changeme
BROKER_URL=https://api.yourdomain.com

# --- Stream routing ---
# Public hostname of the stream-server (used to build stream_url for the frontend)
STREAM_PUBLIC_HOST=stream.yourdomain.com
STREAM_SCHEME=https
# Wildcard subdomain base — stream-client containers are reachable at <kind><slot>.<STREAM_DOMAIN>
STREAM_DOMAIN=stream.yourdomain.com

# --- Stream-agent (on stream-server) ---
STREAM_AGENT_URL=http://<stream-server-ip>:8090
STREAM_AGENT_KEY=changeme

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-sonnet-4-6

# --- Minecraft RCON ---
RCON_PASSWORD=changeme

# --- Caddy ---
FRONTEND_DOMAIN=yourdomain.com
BROKER_DOMAIN=api.yourdomain.com

# --- Optional: image registry (leave blank to use locally-built images) ---
# IMAGE_REGISTRY=ghcr.io/yourorg/
# IMAGE_TAG=latest

# --- VTuber / narration ---
ELEVENLABS_API_KEY=
YOUTUBE_STREAM_KEY=
NARRATION_MODEL=claude-haiku-4-5-20251001

# --- /demo browser-side avatar ---
# URL the Next.js /demo-avatar rewrite proxies to. Must be reachable
# from the game-server (not the visitor's browser). With
# STREAM_DOMAIN=stream.claudetorio.ai, the stream-server's Caddy
# already serves the vtuber-overlay container at this URL via the
# *.stream.claudetorio.ai wildcard cert:
AVATAR_BACKEND_URL=https://vtuber.stream.claudetorio.ai

# --- /demo voice + Kat agent ---
# Groq Whisper is used for transcription on /demo (push-to-talk).
GROQ_API_KEY=

# Override the default ElevenLabs voice for Kat (defaults to the
# "pitch" voice id below).
# VOICE_ID=jqcCZkN6Knx8BJ5TBdYR
