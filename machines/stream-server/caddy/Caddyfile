{
	email {$STREAM_TLS_EMAIL}

	on_demand_tls {
		ask http://stream-agent:8090/health
	}
}

*.{$STREAM_DOMAIN} {
	tls {
		on_demand
	}

	# vtuber.<domain> — Open-LLM-VTuber browser embed (used by the
	# frontend's /demo-avatar Next.js rewrite). With ENABLE_RECORDING=0
	# (the default in the new model), nothing serves on :3000, so we
	# point the existing matcher straight at :12393. Anyone debugging
	# the legacy HLS-compositing pipeline can flip ENABLE_RECORDING=1
	# AND temporarily change this matcher to :3000.
	@vtuberPersistent header host vtuber.{$STREAM_DOMAIN}
	handle @vtuberPersistent {
		reverse_proxy vtuber-overlay:12393
	}

	# Plugin stream-client preview at <kind><slot>.<domain> — used by the
	# frontend's session view as the raw game footage URL.
	@streamMatch header_regexp host Host ^([a-z0-9-]+?)([0-9]+)\.
	handle @streamMatch {
		reverse_proxy stream-client-{re.host.1}-{re.host.2}:3000
	}
}
