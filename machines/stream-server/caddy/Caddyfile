{
	email {$STREAM_TLS_EMAIL}

	on_demand_tls {
		ask http://stream-agent:8090/health
	}
}

*.{$STREAM_DOMAIN} {
	tls {
		on_demand
	}

	# Persistent vtuber-overlay HLS preview at vtuber.<domain>. The vtuber
	# pushes RTMP directly to YouTube; this route is only useful for
	# debugging the local HLS output.
	@vtuberPersistent header host vtuber.{$STREAM_DOMAIN}
	handle @vtuberPersistent {
		reverse_proxy vtuber-overlay:3000
	}

	# Plugin stream-client preview at <kind><slot>.<domain> — used by the
	# frontend's session view as the raw game footage URL.
	@streamMatch header_regexp host Host ^([a-z0-9-]+?)([0-9]+)\.
	handle @streamMatch {
		reverse_proxy stream-client-{re.host.1}-{re.host.2}:3000
	}
}
