# --- Stream-agent auth (must match game-server STREAM_AGENT_KEY) ---
STREAM_AGENT_KEY=changeme

# --- Caddy TLS ---
STREAM_DOMAIN=stream.yourdomain.com
STREAM_TLS_EMAIL=you@yourdomain.com

# --- Optional: image registry ---
# IMAGE_REGISTRY=ghcr.io/yourorg/
# IMAGE_TAG=latest

# --- Persistent vtuber-overlay ---
# Public broker URL the vtuber polls for current-source. Must be reachable
# from this server (HTTPS over Caddy in prod, or http://broker:8080 if
# game- and stream-server are on the same Docker network).
BROKER_URL=https://broker.yourdomain.com
BROKER_ADMIN_KEY=changeme

# YouTube Live ingest. Get the persistent (default) stream key from
# Studio → Go Live → Stream tab. With this set, RTMP push starts once at
# vtuber-overlay container boot and runs forever — Go Live is a one-time
# click in YouTube Studio.
YOUTUBE_STREAM_KEY=

# Anthropic + ElevenLabs for narration + TTS. Without ANTHROPIC_API_KEY the
# narrator + OLV server are skipped (HLS preview still works). Without
# ELEVENLABS_API_KEY, OLV falls back to free edge_tts.
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
NARRATION_MODEL=claude-haiku-4-5-20251001

# Persona — single fixed character for the whole 24/7 stream.
CHARACTER_NAME=Claude
LIVE2D_MODEL=mao_pro
VOICE_ID=jqcCZkN6Knx8BJ5TBdYR
PERSONA_PROMPT=
