# Copy to dev/.env and fill in.

# Anthropic
ANTHROPIC_API_KEY=

# Broker
BROKER_ADMIN_KEY=dev

# Model for all agents by default
MODEL=claude-sonnet-4-5-20250929

# Factorio server RCON password (must match what factoriotools/factorio respects)
RCON_PASSWORD=psychic_train_rcon

# ---- VTuber overlay (optional) ----
# When set, vtuber-overlay containers use this for TTS. Without it, Claude avatar
# animates text-only (no voice).
ELEVENLABS_API_KEY=

# Narration model (defaults to claude-haiku-4-5-20251001 in broker).
NARRATION_MODEL=

# RTMP destination (optional — HLS is always produced regardless).
# YouTube Live ingest: rtmp://a.rtmp.youtube.com/live2/${YOUTUBE_STREAM_KEY}
# When set, the persistent vtuber-overlay starts pushing RTMP at boot and
# keeps the connection open across session swaps — so YouTube only needs
# Go Live one time, ever.
YOUTUBE_STREAM_KEY=

# ---- Persistent vtuber persona (one fixed character for all sessions) ----
# These are baked into the OLV server's conf.yaml at vtuber-overlay startup
# and are NOT hot-reloadable — change them and the container will need to
# restart (which disconnects RTMP). Defaults work; override only if needed.
CHARACTER_NAME=Claude
LIVE2D_MODEL=mao_pro
VOICE_ID=jqcCZkN6Knx8BJ5TBdYR
PERSONA_PROMPT=
