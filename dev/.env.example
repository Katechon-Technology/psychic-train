# Copy to dev/.env and fill in.

# Anthropic
ANTHROPIC_API_KEY=

# Broker
BROKER_ADMIN_KEY=dev

# Model for all agents by default
MODEL=claude-sonnet-4-5-20250929

# Factorio server RCON password (must match what factoriotools/factorio respects)
RCON_PASSWORD=psychic_train_rcon

# ---- VTuber overlay (optional) ----
# When set, vtuber-overlay containers use this for TTS. Without it, Claude avatar
# animates text-only (no voice).
ELEVENLABS_API_KEY=

# Narration model (defaults to claude-haiku-4-5-20251001 in broker).
NARRATION_MODEL=

# RTMP destinations (optional — HLS is always produced regardless).
TWITCH_STREAM_KEY=
KICK_STREAM_KEY=
